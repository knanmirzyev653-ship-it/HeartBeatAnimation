<!DOCTYPE html><html lang="az">
<head>
<meta charset="UTF-8">
<title>8 Mart</title><style>

body{
margin:0;
background:black;
overflow:hidden;
font-family:Arial;
}

#text{
position:absolute;
top:50%;
left:50%;
transform:translate(-50%,-50%);
color:red;
font-size:40px;
text-align:center;
text-shadow:0 0 20px red;
}

canvas{
display:block;
}

</style></head><body><div id="text">
8 Mart bayramını təbrik edirəm anam<br>
Yaxşı ki varsan ❤️
</div><canvas id="c"></canvas>

<script>

const canvas=document.getElementById("c");
const ctx=canvas.getContext("2d");

canvas.width=window.innerWidth;
canvas.height=window.innerHeight;

let particles=[];
let time=0;

function heart(t){
return{
x:16*Math.pow(Math.sin(t),3),
y:13*Math.cos(t)-5*Math.cos(2*t)-2*Math.cos(3*t)-Math.cos(4*t)
}
}

for(let i=0;i<800;i++){

let t=Math.random()*Math.PI*2;
let p=heart(t);

particles.push({

tx:canvas.width/2+p.x*15,
ty:canvas.height/2-p.y*15,

x:Math.random()*canvas.width,
y:Math.random()*canvas.height

})

}

function draw(){

ctx.fillStyle="rgba(0,0,0,0.2)";
ctx.fillRect(0,0,canvas.width,canvas.height);

time+=0.02;

particles.forEach(p=>{

let targetX=p.tx;
let targetY=p.ty;

if(Math.sin(time)>0){

p.x+=(targetX-p.x)*0.05
p.y+=(targetY-p.y)*0.05

}else{

p.x+=(Math.random()*canvas.width-p.x)*0.01
p.y+=(Math.random()*canvas.height-p.y)*0.01

}

ctx.beginPath();
ctx.arc(p.x,p.y,2,0,Math.PI*2);
ctx.fillStyle="red";
ctx.fill();

})

requestAnimationFrame(draw)

}

draw()

</script></body>
</html>
